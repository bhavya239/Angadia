# MongoDB (Atlas or local). Paste your connection string as MONGODB_URI.
MONGODB_URI=mongodb://localhost:27017/angadia_dev

# Backend
JWT_SECRET=change-me-to-a-long-random-secret-at-least-256-bits
SERVER_PORT=8080
# Comma-separated browser origins allowed to call the API (include your Vercel URL).
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Frontend — optional; defaults to same-origin /api/v1 (proxied by Vercel middleware when BACKEND_URL is set).
VITE_API_BASE_URL=

# Vercel only — Spring Boot origin (no trailing slash). Edge middleware proxies /api/* → {BACKEND_URL}/api/*
BACKEND_URL=https://your-api-host.example.com
