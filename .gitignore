# ===========================
#  Angadia Pedhi — .gitignore
# ===========================

# Java / Maven
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# IDE
.idea/
*.iml
*.iws
.classpath
.project
.settings/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vscode/settings.json

# Node / npm
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/.env.production

# Env files (NEVER commit secrets)
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Docker
*.pid
