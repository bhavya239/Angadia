{
  "name": "angadia-pedhi-root",
  "version": "1.0.0",
  "scripts": {
    "dev:backend": "cd backend && mvnw spring-boot:run",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && mvnw clean package -DskipTests",
    "build": "npm run build:frontend",
    "mongo:start": "docker compose up -d mongodb",
    "mongo:stop": "docker compose down",
    "docker:up": "docker compose up --build -d",
    "seed": "cd scripts && node seed.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
